{% doc %}
  @prompt
    crée moi une section une section video with texte. en desktop elle doit afficher la video sur un coté et le texte de l'autre, en mobile la video en haut et le texte en bas
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-text-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-video-text-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 40px;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  @media screen and (min-width: 750px) {
    .ai-video-text-container-{{ ai_gen_id }} {
      flex-direction: {% if block.settings.layout == 'video_left' %}row{% else %}row-reverse{% endif %};
      align-items: center;
      gap: 60px;
    }
  }

  .ai-video-text-video-wrapper-{{ ai_gen_id }} {
    flex: 1;
    width: 100%;
  }

  .ai-video-text-video-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.video_border_radius }}px;
    display: block;
  }

  .ai-video-text-video-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.video_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-video-text-video-placeholder-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    opacity: 0.3;
  }

  .ai-video-text-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-video-text-content-{{ ai_gen_id }} {
    flex: 1;
    width: 100%;
  }

  .ai-video-text-heading-{{ ai_gen_id }} {
    margin: 0 0 20px 0;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-video-text-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-video-text-text-{{ ai_gen_id }} p {
    margin: 0 0 16px 0;
  }

  .ai-video-text-text-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-video-text-button-wrapper-{{ ai_gen_id }} {
    margin-top: 24px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-video-text-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    transition: background-color 0.3s ease;
  }

  .ai-video-text-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }
{% endstyle %}

<video-text-{{ ai_gen_id }} class="ai-video-text-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-video-text-container-{{ ai_gen_id }}">
    <div class="ai-video-text-video-wrapper-{{ ai_gen_id }}">
      {% if block.settings.video %}
        <video
          class="ai-video-text-video-{{ ai_gen_id }}"
          {% if block.settings.autoplay %}autoplay{% endif %}
          {% if block.settings.loop %}loop{% endif %}
          {% if block.settings.muted %}muted{% endif %}
          {% if block.settings.controls %}controls{% endif %}
          playsinline
        >
          <source src="{{ block.settings.video }}" type="video/mp4">
          Votre navigateur ne supporte pas la lecture de vidéos.
        </video>
      {% else %}
        <div class="ai-video-text-video-placeholder-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="5 3 19 12 5 21 5 3"></polygon>
          </svg>
          <div class="ai-video-text-empty-state-{{ ai_gen_id }}">
            Ajoutez une vidéo
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-video-text-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-video-text-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-video-text-text-{{ ai_gen_id }}">
          {{ block.settings.text }}
        </div>
      {% endif %}

      {% if block.settings.button_text != blank and block.settings.button_link != blank %}
        <div class="ai-video-text-button-wrapper-{{ ai_gen_id }}">
          <a href="{{ block.settings.button_link }}" class="ai-video-text-button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </a>
        </div>
      {% endif %}
    </div>
  </div>
</video-text-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoText{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const video = this.querySelector('.ai-video-text-video-{{ ai_gen_id }}');
        if (video) {
          video.addEventListener('loadedmetadata', function() {
            video.style.aspectRatio = video.videoWidth + ' / ' + video.videoHeight;
          });
        }
      }
    }

    customElements.define('video-text-{{ ai_gen_id }}', VideoText{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Vidéo avec texte",
  "settings": [
    {
      "type": "header",
      "content": "Disposition"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Position de la vidéo (desktop)",
      "options": [
        {
          "value": "video_left",
          "label": "Vidéo à gauche"
        },
        {
          "value": "video_right",
          "label": "Vidéo à droite"
        }
      ],
      "default": "video_left"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Largeur desktop",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Vidéo"
    },
    {
      "type": "url",
      "id": "video",
      "label": "Lien vidéo"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Lecture automatique",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Lecture en boucle",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "muted",
      "label": "Muet",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "controls",
      "label": "Afficher les contrôles",
      "default": true
    },
    {
      "type": "range",
      "id": "video_border_radius",
      "label": "Arrondi des coins",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Contenu"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Titre",
      "default": "Découvrez notre vidéo"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texte",
      "default": "<p>Ajoutez une description pour accompagner votre vidéo et engager vos visiteurs.</p>"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alignement du texte",
      "options": [
        {
          "value": "left",
          "label": "Gauche"
        },
        {
          "value": "center",
          "label": "Centre"
        },
        {
          "value": "right",
          "label": "Droite"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Bouton"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texte du bouton",
      "default": "En savoir plus"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Lien du bouton"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Taille du titre",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Taille du texte",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_text_size",
      "label": "Taille du texte du bouton",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Arrondi du bouton",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Couleur du titre",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur du texte",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Fond du bouton",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Texte du bouton",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Fond du bouton au survol",
      "default": "#ff6a00"
    }
  ],
  "presets": [
    {
      "name": "Vidéo avec texte"
    }
  ]
}
{% endschema %}
