<script>
  (function(){
    var s = document.createElement('style');
    s.id = 'vd-hide-global';
    s.textContent = ''
      + '.shopify-section-group-header-group,'
      + '.shopify-section-group-footer-group,'
      + '.shopify-section--announcement-bar,'
      + '.shopify-section--header,'
      + '.shopify-section--footer,'
      + '#shopify-section-header,'
      + '#shopify-section-footer,'
      + '[id*="announcement-bar"],'
      + '[id*="__header"],'
      + '[id*="__footer"]{display:none!important;visibility:hidden!important;height:0!important;margin:0!important;padding:0!important;border:0!important;overflow:hidden!important;}'
      + 'html,body{background:#FFFFFF!important;}'
      + 'body{padding-top:0!important;margin-top:0!important;--header-height:0px!important;--announcement-bar-height:0px!important;--sticky-area-height:0px!important;}';
    (document.head || document.documentElement).appendChild(s);
  })();
</script>

<style>
  :root {
    --vd-bg:        #FFFFFF;
    --vd-surface:   #F4F1EC;
    --vd-surface-2: #FAF7F1;
    --vd-ink:       #0A0A0A;
    --vd-body:      #2B2B2B;
    --vd-mute:      #7A7163;
    --vd-line:      #ECE7DD;
    --vd-line-2:    #D9D3C5;
    --vd-red:       #D81B22;
    --vd-red-deep:  #A0141A;
    --vd-tan:       #8B5A2B;
  }
  .vd { background:var(--vd-bg); color:var(--vd-body); font-family:'Montserrat', system-ui, -apple-system, sans-serif; -webkit-font-smoothing:antialiased; line-height:1.7; padding-bottom:96px; }
  .vd *, .vd *::before, .vd *::after { box-sizing:border-box; }
  .vd a { color:inherit; }
  .vd-article p a, .vd-update p a { color:var(--vd-red); text-decoration:underline; text-decoration-thickness:1px; text-underline-offset:3px; font-weight:500; }
  .vd-article p a:hover, .vd-update p a:hover { color:var(--vd-red-deep); }

  .vd-wrap { max-width:680px; margin:0 auto; padding:0 22px; }
  .vd-wrap-wide { max-width:1080px; margin:0 auto; padding:0 22px; }

  /* MASTHEAD */
  .vd-masthead { border-bottom:1px solid var(--vd-line-2); padding:16px 0; background:var(--vd-bg); }
  .vd-masthead-inner { display:flex; align-items:center; justify-content:space-between; gap:14px; }
  .vd-pub { font-weight:800; font-size:11px; letter-spacing:.34em; color:var(--vd-ink); text-transform:uppercase; }
  .vd-pub .sep { color:var(--vd-mute); margin:0 8px; font-weight:400; }
  .vd-pub-tag { font-size:10px; letter-spacing:.18em; color:var(--vd-mute); text-transform:uppercase; }
  .vd-pub-tag .red { color:var(--vd-red); font-weight:700; }

  /* HERO */
  .vd-hero { padding:64px 0 0; }
  .vd-cat { display:inline-flex; align-items:center; gap:12px; font-size:11px; letter-spacing:.24em; text-transform:uppercase; color:var(--vd-red); font-weight:800; margin-bottom:28px; }
  .vd-cat::before { content:""; width:28px; height:1px; background:var(--vd-red); display:inline-block; }
  .vd-cat .num { background:var(--vd-red); color:#fff; padding:3px 7px; font-size:9.5px; letter-spacing:.12em; margin-right:6px; }
  .vd-h1 { font-family:'Montserrat', sans-serif; font-weight:800; font-size:clamp(36px, 6.4vw, 60px); line-height:1.04; letter-spacing:-0.028em; color:var(--vd-ink); margin:0 0 22px; }
  .vd-h1 em { font-style:italic; font-weight:600; color:var(--vd-red); }
  .vd-lede { font-size:clamp(17px,2vw,20px); color:var(--vd-body); max-width:620px; margin:0 0 32px; font-weight:400; line-height:1.55; }
  .vd-lede strong { color:var(--vd-ink); font-weight:600; }

  /* AUTHOR */
  .vd-author { display:flex; align-items:center; gap:14px; padding:22px 0 28px; border-top:1px solid var(--vd-line-2); border-bottom:1px solid var(--vd-line-2); margin-bottom:32px; }
  .vd-author img { width:50px; height:50px; border-radius:50%; object-fit:cover; border:1px solid var(--vd-line-2); }
  .vd-author-meta { display:flex; flex-direction:column; gap:3px; }
  .vd-author-name { font-weight:700; font-size:13.5px; color:var(--vd-ink); letter-spacing:.01em; }
  .vd-author-role { font-size:11.5px; color:var(--vd-mute); letter-spacing:.04em; }
  .vd-author-meta-sub { font-size:10.5px; color:var(--vd-mute); letter-spacing:.08em; margin-top:2px; text-transform:uppercase; font-weight:600; }
  .vd-author-meta-sub .dot { margin:0 7px; color:var(--vd-line-2); }

  /* HERO IMG */
  .vd-hero-img { margin:0 0 18px; }
  .vd-hero-img img { width:100%; height:auto; display:block; }
  .vd-figcap { font-size:12px; color:var(--vd-mute); letter-spacing:.01em; padding:12px 0 0; font-style:italic; line-height:1.55; }
  .vd-figcap b { font-style:normal; color:var(--vd-body); text-transform:uppercase; font-size:10.5px; letter-spacing:.16em; margin-right:6px; font-weight:700; }

  /* ARTICLE */
  .vd-article { padding:40px 0 24px; }
  .vd-article p { font-size:17px; color:var(--vd-body); margin:0 0 24px; font-weight:400; }
  .vd-article p strong { color:var(--vd-ink); font-weight:600; }
  .vd-article p:first-of-type::first-letter { float:left; font-family:'Montserrat', serif; font-weight:800; font-size:78px; line-height:.84; color:var(--vd-ink); padding:6px 12px 0 0; }
  .vd-article h2 { font-family:'Montserrat', sans-serif; font-weight:700; font-size:clamp(22px,3.4vw,30px); line-height:1.18; letter-spacing:-0.015em; color:var(--vd-ink); margin:48px 0 18px; }
  .vd-article h2::before { content:""; display:block; width:34px; height:2px; background:var(--vd-red); margin-bottom:14px; }
  .vd-article h2 .step { display:inline-block; font-family:'Montserrat', sans-serif; font-weight:800; font-size:11px; color:var(--vd-red); letter-spacing:.18em; text-transform:uppercase; margin-right:10px; vertical-align:middle; }

  /* PULL QUOTE Vox-style */
  .vd-pull { margin:38px -8px; padding:26px 30px; background:var(--vd-surface); border-left:3px solid var(--vd-red); }
  .vd-pull-text { font-family:'Montserrat', sans-serif; font-style:italic; font-weight:500; font-size:clamp(19px,2.5vw,24px); line-height:1.42; color:var(--vd-ink); margin:0 0 14px; letter-spacing:-0.012em; }
  .vd-pull-attr { font-size:11px; letter-spacing:.16em; text-transform:uppercase; color:var(--vd-mute); font-weight:700; }

  /* FIGURE */
  .vd-fig { margin:40px 0; }
  .vd-fig img { width:100%; height:auto; display:block; }
  .vd-fig-wide { margin-left:calc(50% - 50vw); margin-right:calc(50% - 50vw); max-width:none; }
  @media(min-width:768px){ .vd-fig-wide { margin-left:calc(-1*((100vw - 680px)/2)); margin-right:calc(-1*((100vw - 680px)/2)); } }

  /* VIDEO DEMO — 1:1 centered, no controls */
  .vd-video { margin:52px 0 0; display:flex; justify-content:center; background:transparent; }
  .vd-video .vd-video-frame { position:relative; width:100%; max-width:560px; aspect-ratio:1/1; background:#000; overflow:hidden; }
  .vd-video video { width:100%; height:100%; display:block; object-fit:cover; pointer-events:none; }
  .vd-video .vd-video-tag { position:absolute; left:14px; top:14px; background:rgba(255,255,255,.94); border-left:2px solid var(--vd-red); padding:7px 11px; font-size:10px; letter-spacing:.22em; text-transform:uppercase; color:var(--vd-red); font-weight:800; z-index:2; -webkit-backdrop-filter:blur(8px); backdrop-filter:blur(8px); }
  .vd-video-caption { margin:0 0 52px; padding-top:14px; text-align:center; }

  /* IN-USE PROOF (Velvy D in car) */
  .vd-proof { margin:52px 0; position:relative; }
  .vd-proof img { width:100%; height:auto; display:block; }
  .vd-proof-overlay { position:absolute; left:22px; bottom:22px; max-width:340px; background:rgba(255,255,255,.94); -webkit-backdrop-filter:blur(8px); backdrop-filter:blur(8px); padding:20px 22px; border-left:2px solid var(--vd-red); }
  .vd-proof-overlay .label { font-size:10px; letter-spacing:.22em; text-transform:uppercase; color:var(--vd-red); font-weight:800; margin-bottom:9px; }
  .vd-proof-overlay .txt { font-size:13.5px; line-height:1.55; color:var(--vd-ink); font-weight:500; }
  @media(max-width:600px){ .vd-proof-overlay { position:static; max-width:none; border-left:none; border-top:2px solid var(--vd-red); margin-top:0; } }

  /* STATS — NYT Well style */
  .vd-stats { display:grid; grid-template-columns:repeat(3,1fr); gap:0; margin:32px 0 12px; padding:0; border-top:1px solid var(--vd-line-2); border-bottom:1px solid var(--vd-line-2); }
  .vd-stat { text-align:center; padding:28px 14px; border-right:1px solid var(--vd-line-2); }
  .vd-stat:last-child { border-right:none; }
  .vd-stat .n { font-family:'Montserrat', sans-serif; font-weight:800; font-size:36px; color:var(--vd-ink); line-height:1; letter-spacing:-0.025em; }
  .vd-stat .n .u { font-size:18px; color:var(--vd-red); font-weight:700; margin-left:2px; }
  .vd-stat .l { font-size:10.5px; color:var(--vd-mute); letter-spacing:.14em; text-transform:uppercase; margin-top:10px; font-weight:700; }

  /* COMPARE */
  .vd-compare-wrap { margin:44px 0; }
  .vd-compare-h { font-size:10.5px; letter-spacing:.22em; text-transform:uppercase; color:var(--vd-mute); font-weight:800; margin-bottom:16px; }
  .vd-compare { display:grid; grid-template-columns:1fr; gap:14px; }
  @media(min-width:640px){ .vd-compare { grid-template-columns:1fr 1fr; gap:18px; } }
  .vd-c-card { background:var(--vd-surface); border:1px solid var(--vd-line-2); padding:28px 22px; }
  .vd-c-card.bad { border-top:3px solid var(--vd-red); }
  .vd-c-card.good { border-top:3px solid var(--vd-tan); }
  .vd-c-tag { font-size:10px; letter-spacing:.2em; text-transform:uppercase; font-weight:800; color:var(--vd-mute); margin-bottom:12px; }
  .vd-c-card h3 { font-size:19px; font-weight:700; color:var(--vd-ink); margin:0 0 18px; letter-spacing:-0.005em; }
  .vd-c-card ul { list-style:none; padding:0; margin:0; }
  .vd-c-card li { padding:11px 0 11px 24px; position:relative; color:var(--vd-body); font-size:14.5px; line-height:1.55; border-top:1px solid var(--vd-line-2); }
  .vd-c-card li:first-child { border-top:none; padding-top:2px; }
  .vd-c-card.bad li::before { content:"—"; position:absolute; left:0; color:var(--vd-red); font-weight:700; font-size:16px; }
  .vd-c-card.good li::before { content:"+"; position:absolute; left:0; color:var(--vd-tan); font-weight:700; font-size:18px; }

  /* TESTIMONIALS */
  .vd-test { margin:52px 0 12px; padding:40px 0; border-top:1px solid var(--vd-line-2); border-bottom:1px solid var(--vd-line-2); }
  .vd-test-h { font-size:10.5px; letter-spacing:.22em; text-transform:uppercase; color:var(--vd-mute); font-weight:800; margin-bottom:26px; }
  .vd-test-grid { display:grid; grid-template-columns:1fr; gap:24px; }
  @media(min-width:768px){ .vd-test-grid { grid-template-columns:repeat(3,1fr); gap:26px; } }
  .vd-test-card { font-size:14.5px; line-height:1.6; }
  .vd-test-card .q { color:var(--vd-ink); margin-bottom:14px; font-weight:400; }
  .vd-test-card .q::before { content:"\201C"; color:var(--vd-red); font-family:serif; font-size:38px; line-height:0; vertical-align:-12px; margin-right:4px; }
  .vd-test-card .a { font-size:10.5px; letter-spacing:.12em; text-transform:uppercase; color:var(--vd-mute); font-weight:700; }
  .vd-test-card .a .stars { color:var(--vd-tan); margin-right:7px; letter-spacing:0; font-size:12px; }

  /* ============== SHOP SECTION (replaces offer block) ============== */
  .vd-shop { margin:72px 0 32px; scroll-margin-top:20px; }
  .vd-shop-eyebrow { display:flex; align-items:center; gap:10px; font-size:10.5px; letter-spacing:.22em; text-transform:uppercase; color:var(--vd-red); font-weight:800; margin-bottom:20px; }
  .vd-shop-eyebrow::before { content:""; display:block; width:28px; height:1px; background:var(--vd-red); }

  .vd-shop-grid { display:grid; grid-template-columns:1fr; gap:28px; background:var(--vd-surface-2); border:1px solid var(--vd-line-2); padding:24px; }
  @media(min-width:760px){ .vd-shop-grid { grid-template-columns:1fr 1fr; gap:36px; padding:32px; align-items:start; } }

  .vd-shop-images { position:relative; }
  .vd-shop-main { width:100%; aspect-ratio:1/1; object-fit:cover; display:block; background:var(--vd-surface); }
  .vd-shop-thumbs { display:grid; grid-template-columns:repeat(4,1fr); gap:8px; margin-top:10px; }
  .vd-shop-thumb { background:none; border:1px solid var(--vd-line-2); padding:0; cursor:pointer; aspect-ratio:1/1; overflow:hidden; transition:border-color .15s ease; }
  .vd-shop-thumb img { width:100%; height:100%; object-fit:cover; display:block; }
  .vd-shop-thumb.active { border-color:var(--vd-red); }

  .vd-shop-info { display:flex; flex-direction:column; }
  .vd-shop-label { font-size:10.5px; letter-spacing:.22em; text-transform:uppercase; color:var(--vd-tan); font-weight:800; margin-bottom:10px; }
  .vd-shop-title { font-family:'Montserrat', sans-serif; font-weight:700; font-size:clamp(24px,3.4vw,32px); line-height:1.12; letter-spacing:-0.02em; color:var(--vd-ink); margin:0 0 12px; }
  .vd-shop-rating { display:flex; align-items:center; gap:8px; font-size:12px; color:var(--vd-mute); margin-bottom:18px; letter-spacing:.02em; font-weight:600; }
  .vd-shop-rating .stars { color:var(--vd-tan); letter-spacing:1px; font-size:14px; }

  .vd-shop-price { display:flex; align-items:baseline; gap:10px; margin-bottom:22px; flex-wrap:wrap; }
  .vd-shop-price .from { font-size:11px; letter-spacing:.18em; text-transform:uppercase; color:var(--vd-mute); font-weight:700; }
  .vd-shop-price .price { font-family:'Montserrat', sans-serif; font-weight:800; font-size:38px; color:var(--vd-ink); letter-spacing:-0.03em; line-height:1; }
  .vd-shop-price .old { font-size:15px; color:var(--vd-mute); text-decoration:line-through; }
  .vd-shop-price .save { font-size:10.5px; letter-spacing:.14em; text-transform:uppercase; color:#fff; font-weight:800; background:var(--vd-red); padding:4px 8px; }
  .vd-shop-stock { font-size:11px; color:var(--vd-tan); letter-spacing:.1em; text-transform:uppercase; font-weight:700; margin-bottom:20px; }
  .vd-shop-stock::before { content:"●"; color:#7be39a; margin-right:6px; font-size:9px; vertical-align:1px; }

  .vd-shop-feat { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:22px; }
  .vd-shop-feat span { font-size:11px; color:var(--vd-body); padding:6px 10px; background:var(--vd-surface); border:1px solid var(--vd-line-2); font-weight:600; letter-spacing:.02em; }
  .vd-shop-feat span::before { content:"+"; color:var(--vd-tan); font-weight:700; margin-right:5px; }

  .vd-shop-color { margin-bottom:22px; }
  .vd-shop-color-lab { font-size:11px; letter-spacing:.16em; text-transform:uppercase; color:var(--vd-mute); font-weight:700; margin-bottom:10px; }
  .vd-shop-color-lab b { color:var(--vd-ink); font-weight:800; margin-left:6px; }
  .vd-shop-swatches { display:flex; flex-wrap:wrap; gap:10px; }
  .vd-shop-swatch { width:36px; height:36px; border-radius:50%; border:1px solid var(--vd-line-2); padding:0; cursor:pointer; position:relative; transition:transform .15s ease; }
  .vd-shop-swatch::after { content:""; position:absolute; inset:-5px; border:1.5px solid transparent; border-radius:50%; transition:border-color .15s ease; }
  .vd-shop-swatch.active::after { border-color:var(--vd-red); }
  .vd-shop-swatch:hover { transform:scale(1.05); }

  .vd-shop-cta { width:100%; padding:18px 22px; font-size:13.5px; letter-spacing:.18em; text-align:center; }
  .vd-shop-cta[data-state="added"] { background:#1f3d23; color:#aef2bb; }
  .vd-shop-reassure { margin-top:12px; font-size:11px; letter-spacing:.08em; color:var(--vd-mute); text-align:center; font-weight:600; line-height:1.5; }
  .vd-shop-trust { display:flex; gap:14px; margin-top:14px; font-size:10.5px; letter-spacing:.12em; text-transform:uppercase; color:var(--vd-mute); flex-wrap:wrap; font-weight:700; }
  .vd-shop-trust span::before { content:"✓"; color:var(--vd-tan); margin-right:5px; }

  .vd-shop-error { display:none; margin-top:10px; color:var(--vd-red); font-size:12px; font-weight:600; }

  /* BTN */
  .vd-btn { display:inline-block; background:var(--vd-ink); color:var(--vd-bg); padding:17px 30px; border-radius:0; text-decoration:none; font-weight:700; font-size:13px; letter-spacing:.16em; text-transform:uppercase; transition:background .2s ease, color .2s ease, transform .15s ease; border:none; cursor:pointer; line-height:1; }
  .vd-btn:hover { background:var(--vd-red); color:#fff; transform:translateY(-1px); }
  .vd-btn.alt { background:var(--vd-red); color:#fff; }
  .vd-btn.alt:hover { background:var(--vd-ink); color:var(--vd-bg); }
  .vd-btn:disabled { opacity:.7; cursor:wait; transform:none; }

  /* FAQ */
  .vd-faq { padding:52px 0 30px; }
  .vd-faq h2 { font-weight:700; font-size:22px; color:var(--vd-ink); margin:0 0 22px; letter-spacing:-0.01em; }
  .vd-faq details { border-bottom:1px solid var(--vd-line-2); padding:18px 0; cursor:pointer; }
  .vd-faq summary { font-weight:600; font-size:15px; list-style:none; display:flex; justify-content:space-between; align-items:center; color:var(--vd-ink); gap:18px; }
  .vd-faq summary::-webkit-details-marker { display:none; }
  .vd-faq summary::after { content:"+"; color:var(--vd-red); font-size:22px; line-height:1; flex-shrink:0; }
  .vd-faq details[open] summary::after { content:"–"; }
  .vd-faq details p { margin:14px 0 0; color:var(--vd-body); font-size:14.5px; line-height:1.6; }

  /* UPDATE NOTICE */
  .vd-update { background:#FFF9E6; border-left:4px solid #E0A100; padding:22px 26px; margin:48px 0 24px; font-size:14.5px; line-height:1.65; }
  .vd-update-h { font-size:11px; letter-spacing:.22em; text-transform:uppercase; color:#9A6A00; font-weight:800; margin-bottom:10px; }
  .vd-update p { margin:0; color:#1A1A1A; font-weight:500; }
  .vd-update p strong { color:#0A0A0A; font-weight:800; }

  /* DISCLOSURE */
  .vd-discl { padding:34px 0 30px; font-size:11.5px; color:var(--vd-mute); line-height:1.6; border-top:1px solid var(--vd-line-2); margin-top:24px; letter-spacing:.01em; }

  /* FB COMMENTS */
  .vd-fb { font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Helvetica,Arial,sans-serif; padding:32px 0 60px; }
  .vd-fb-h { font-size:16px; font-weight:700; color:#050505; margin:0 0 18px; letter-spacing:.005em; }
  .vd-fb-add { background:#fff; border:1px solid #ced0d4; border-radius:18px; padding:9px 16px; font-size:13.5px; color:#65676b; margin-bottom:22px; cursor:text; }
  .vd-fb-list { display:flex; flex-direction:column; gap:14px; }
  .vd-fb-c { display:flex; gap:8px; }
  .vd-fb-c > img { width:36px; height:36px; border-radius:50%; flex-shrink:0; object-fit:cover; background:#e4e6eb; }
  .vd-fb-body { flex:1; min-width:0; }
  .vd-fb-bubble { background:#f0f2f5; border-radius:16px; padding:8px 12px; display:inline-block; max-width:100%; position:relative; }
  .vd-fb-name { font-weight:600; font-size:13px; color:#385898; margin:0 0 1px; line-height:1.25; }
  .vd-fb-text { font-size:14.5px; color:#050505; line-height:1.34; margin:0; word-wrap:break-word; }
  .vd-fb-meta { padding:3px 12px 0; font-size:12px; color:#65676b; display:flex; align-items:center; gap:10px; flex-wrap:wrap; line-height:1.4; }
  .vd-fb-meta .act { font-weight:600; cursor:pointer; }
