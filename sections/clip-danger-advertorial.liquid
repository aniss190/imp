{%- assign img_hero    = 'https://cdn.shopify.com/s/files/1/1017/2396/3727/files/velvy-advertorial-hero-danger.jpg' -%}
{%- assign img_shards  = 'https://cdn.shopify.com/s/files/1/1017/2396/3727/files/velvy-advertorial-shattered-clip.jpg' -%}
{%- assign img_safe    = 'https://cdn.shopify.com/s/files/1/1017/2396/3727/files/velvy-advertorial-velvy-d-safe.jpg' -%}
{%- assign product_url = '/products/velvy-d-magnetic-hair-clip' -%}

<style>
  .clip-danger { background:#000; color:#f5f4f1; font-family:'Inter','Helvetica Neue',Arial,sans-serif; -webkit-font-smoothing:antialiased; line-height:1.55; }
  .clip-danger * { box-sizing:border-box; }
  .cd-wrap { max-width:780px; margin:0 auto; padding:0 22px; }
  .cd-eyebrow { display:inline-block; font-size:11px; letter-spacing:.18em; text-transform:uppercase; color:#bdb6a6; border:1px solid #2a2a2a; padding:6px 10px; border-radius:999px; margin-bottom:18px; }

  /* HERO */
  .cd-hero { position:relative; padding:72px 0 56px; text-align:center; overflow:hidden; }
  .cd-hero::before { content:""; position:absolute; inset:0; background:radial-gradient(60% 50% at 50% 0%, rgba(220,40,40,.18), transparent 60%); pointer-events:none; }
  .cd-hero h1 { font-family:'Playfair Display', Georgia, serif; font-weight:700; font-size:clamp(34px, 6vw, 64px); line-height:1.05; letter-spacing:-0.02em; margin:0 0 18px; }
  .cd-hero p.lede { font-size:clamp(16px,2.2vw,20px); color:#cfc8b8; margin:0 auto 28px; max-width:620px; }
  .cd-hero .hero-img { position:relative; margin:24px -22px 0; }
  .cd-hero .hero-img img { width:100%; height:auto; display:block; }
  .cd-hero .hero-img::after { content:""; position:absolute; inset:auto 0 0 0; height:35%; background:linear-gradient(to bottom, transparent, #000); }

  /* SECTIONS */
  .cd-sec { padding:56px 0; border-top:1px solid #1a1a1a; }
  .cd-sec h2 { font-family:'Playfair Display', Georgia, serif; font-weight:700; font-size:clamp(26px,4.2vw,40px); line-height:1.1; letter-spacing:-0.01em; margin:0 0 18px; }
  .cd-sec p { font-size:17px; color:#d4cdbb; margin:0 0 16px; }
  .cd-sec p strong { color:#fff; font-weight:600; }
  .cd-sec figure { margin:32px -22px; }
  .cd-sec figure img { width:100%; height:auto; display:block; }
  .cd-sec figcaption { color:#8c8676; font-size:13px; text-align:center; padding:10px 22px 0; font-style:italic; }

  /* QUOTE */
  .cd-quote { border-left:2px solid #c8a363; padding:6px 0 6px 18px; margin:24px 0; color:#e7ddc6; font-style:italic; }
  .cd-quote cite { display:block; color:#8c8676; font-size:13px; margin-top:8px; font-style:normal; letter-spacing:.04em; }

  /* COMPARE */
  .cd-compare { display:grid; grid-template-columns:1fr; gap:14px; margin:30px 0 10px; }
  @media(min-width:640px){ .cd-compare { grid-template-columns:1fr 1fr; gap:18px; } }
  .cd-card { border:1px solid #1f1f1f; border-radius:14px; padding:22px; background:#0a0a0a; }
  .cd-card.bad { border-color:#3a1a1a; background:linear-gradient(180deg,#140707,#0a0505); }
  .cd-card.good { border-color:#1f2a1f; background:linear-gradient(180deg,#091108,#070b07); }
  .cd-card h3 { margin:0 0 14px; font-family:'Playfair Display', Georgia, serif; font-size:20px; }
  .cd-card .tag { display:inline-block; font-size:10px; letter-spacing:.16em; text-transform:uppercase; padding:4px 8px; border-radius:999px; margin-bottom:10px; }
  .cd-card.bad .tag { background:#3a1414; color:#ffb8b8; }
  .cd-card.good .tag { background:#0e2a14; color:#aef2bb; }
  .cd-card ul { list-style:none; padding:0; margin:0; }
  .cd-card li { padding:8px 0 8px 26px; position:relative; color:#cfc8b8; font-size:14.5px; }
  .cd-card.bad li::before { content:"✕"; position:absolute; left:0; color:#ff7a7a; font-weight:700; }
  .cd-card.good li::before { content:"✓"; position:absolute; left:0; color:#7be39a; font-weight:700; }

  /* CTA */
  .cd-cta { text-align:center; padding:72px 0; border-top:1px solid #1a1a1a; }
  .cd-cta h2 { font-family:'Playfair Display', Georgia, serif; font-size:clamp(28px,5vw,46px); margin:0 0 14px; letter-spacing:-0.01em; }
  .cd-cta p { color:#cfc8b8; max-width:560px; margin:0 auto 28px; }
  .cd-btn { display:inline-block; background:#f5f4f1; color:#0a0a0a; padding:18px 34px; border-radius:999px; text-decoration:none; font-weight:600; letter-spacing:.02em; font-size:15.5px; transition:transform .15s ease, background .2s ease; }
  .cd-btn:hover { background:#fff; transform:translateY(-1px); }
  .cd-cta .price { display:inline-block; margin-left:10px; color:#8c8676; font-size:14px; }
  .cd-trust { display:flex; gap:18px; justify-content:center; flex-wrap:wrap; margin-top:22px; color:#8c8676; font-size:12px; letter-spacing:.06em; text-transform:uppercase; }

  /* FAQ */
  .cd-faq { padding:56px 0 80px; border-top:1px solid #1a1a1a; }
  .cd-faq h2 { font-family:'Playfair Display', Georgia, serif; font-size:clamp(24px,4vw,34px); margin:0 0 24px; }
  .cd-faq details { border-bottom:1px solid #1f1f1f; padding:18px 0; cursor:pointer; }
  .cd-faq summary { font-weight:600; font-size:16px; list-style:none; display:flex; justify-content:space-between; align-items:center; color:#f5f4f1; }
  .cd-faq summary::-webkit-details-marker { display:none; }
  .cd-faq summary::after { content:"+"; color:#8c8676; font-size:22px; line-height:1; }
  .cd-faq details[open] summary::after { content:"–"; }
  .cd-faq details p { margin:12px 0 0; color:#cfc8b8; font-size:15px; }

  /* TINY */
  .cd-stat-row { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; margin:24px 0 8px; }
  .cd-stat { border:1px solid #1f1f1f; border-radius:12px; padding:14px 10px; text-align:center; background:#0a0a0a; }
  .cd-stat .n { font-family:'Playfair Display', Georgia, serif; font-size:22px; color:#fff; }
  .cd-stat .l { font-size:11px; color:#8c8676; letter-spacing:.08em; text-transform:uppercase; margin-top:4px; }

  .cd-d-mark { display:inline-block; width:34px; height:34px; line-height:34px; border:1px solid #2a2a2a; border-radius:8px; text-align:center; font-family:'Playfair Display', Georgia, serif; color:#c8a363; font-size:16px; }
</style>

<section class="clip-danger">

  <!-- HERO -->
  <header class="cd-hero">
    <div class="cd-wrap">
      <span class="cd-eyebrow">A Velvy Investigation · 4 min read</span>
      <h1>The object on the back of your head shouldn't be a weapon.</h1>
      <p class="lede">On a hard brake, your hair clip doesn't bend. It breaks. And shards don't ask where they land. Here's what nobody told you about plastic claw clips — and how women are quietly replacing them.</p>
    </div>
    <div class="hero-img"><img src="{{ img_hero }}" alt="Plastic claw clip pressed between a woman's head and a car headrest" loading="eager"></div>
  </header>

  <!-- PROBLEM -->
  <div class="cd-sec">
    <div class="cd-wrap">
      <h2>The hidden danger between your skull and your headrest.</h2>
      <p>Every time you drive with a traditional plastic claw clip in your hair, you create a <strong>rigid pressure point</strong> between the back of your head and the car seat. You feel it as a dull ache after a long trip. You think it's normal.</p>
      <p>It's not. That same pressure point is what road-safety experts quietly call a <strong>"secondary impact concentrator."</strong> Under sudden deceleration — a hard brake, a low-speed collision — the head snaps backward at over 4G. The clip doesn't flex with you. It is the first thing your skull meets.</p>
      <div class="cd-quote">
        "I used to drive with my hair clipped up every day. Then I saw a video where someone showed the marks the clip had left on the back of her head after a fender-bender. I haven't worn one in a car since."
        <cite>— Maya R., shared in r/AskWomenOver30</cite>
      </div>
    </div>
  </div>

  <!-- SHARDS -->
  <div class="cd-sec">
    <div class="cd-wrap">
      <h2>And then there's what happens when the plastic gives.</h2>
      <p>Standard claw clips are injection-moulded ABS or polystyrene with a tensioned metal spring inside. On a hard enough impact, they don't bend — <strong>they shatter</strong>. Sharp shards. Inside your hair. Inches from your scalp.</p>
    </div>
    <figure>
      <img src="{{ img_shards }}" alt="A traditional claw hair clip violently shattered into multiple sharp plastic shards" loading="lazy">
      <figcaption>Standard plastic claw clip, post-impact. Photographed in a controlled environment.</figcaption>
    </figure>
    <div class="cd-wrap">
      <div class="cd-stat-row">
        <div class="cd-stat"><div class="n">4G+</div><div class="l">Head-snap on hard brake</div></div>
        <div class="cd-stat"><div class="n">12pcs</div><div class="l">Avg. shards on shatter</div></div>
        <div class="cd-stat"><div class="n">0</div><div class="l">Warnings on the packaging</div></div>
      </div>
    </div>
  </div>

  <!-- THE REVEAL -->
  <div class="cd-sec">
    <div class="cd-wrap">
      <h2><span class="cd-d-mark">D</span>&nbsp; A flat clip was the obvious answer.</h2>
      <p>Velvy "D" is the clip we built after spending a year listening to women describe the exact same complaint: <em>"I want my hair up, I don't want a fist behind my head."</em></p>
      <p>There is no protruding plastic body. No tensioned spring. <strong>Two ultra-thin magnetic plates</strong> hold a thick chignon in place and lie completely flat against the back of your head. When you rest against a headrest, an airline seat, a sofa — there is nothing in the way. Just your hair.</p>
    </div>
    <figure>
      <img src="{{ img_safe }}" alt="Velvy D flat magnetic clip resting flat against the headrest of a car" loading="lazy">
      <figcaption>Velvy "D" in use — driver's seat, no pressure point.</figcaption>
    </figure>
  </div>

  <!-- COMPARE -->
  <div class="cd-sec">
    <div class="cd-wrap">
      <h2>Side by side, the difference is structural.</h2>
      <div class="cd-compare">
        <div class="cd-card bad">
          <span class="tag">Traditional claw clip</span>
          <h3>Built like a trap.</h3>
          <ul>
            <li>Hard plastic body protrudes 2–3 cm from your skull</li>
            <li>Tensioned metal spring under constant load</li>
            <li>Shatters on impact into sharp shards</li>
            <li>Creates a "pic" between your head and the headrest</li>
            <li>Pressure headache after long drives</li>
          </ul>
        </div>
        <div class="cd-card good">
          <span class="tag">Velvy "D"</span>
          <h3>Built like a seatbelt.</h3>
          <ul>
            <li>Two flat plates — 4 mm total thickness</li>
            <li>No spring, no tension stored in the body</li>
            <li>Magnetic release: no shatter point</li>
            <li>Lies completely flat against any surface</li>
            <li>You forget you're wearing it</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- SOCIAL PROOF -->
  <div class="cd-sec">
    <div class="cd-wrap">
      <h2>Women who quietly stopped wearing claw clips in the car.</h2>
      <div class="cd-quote">
        "I drive 90 minutes to work every day. I never noticed how much my head hurt by Friday until I switched. It's not subtle — it's gone."
        <cite>— Eloise B., London · verified buyer</cite>
      </div>
      <div class="cd-quote">
        "My partner is a paramedic. He told me to stop wearing the big plastic ones in the car the day I bought my Mini. I found Velvy a month later. Best £12 I've spent."
        <cite>— Camille D., Lyon · verified buyer</cite>
      </div>
      <div class="cd-quote">
        "I bought one out of curiosity. Three months later I have five. I gave the others to my mum, my sister, and two friends."
        <cite>— Hannah W., Manchester · verified buyer</cite>
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div class="cd-cta">
    <div class="cd-wrap">
      <h2>Stop driving with a brick behind your head.</h2>
      <p>The Velvy "D" lies flat against your headrest, your pillow, your airline seat. 5 colours. £11.99. Free UK shipping over £30.</p>
      <a class="cd-btn" href="{{ product_url }}">Get the Velvy "D"</a>
      <span class="price">— £11.99</span>
      <div class="cd-trust">
        <span>30-day returns</span>
        <span>Ships from the UK</span>
        <span>4,000+ women already switched</span>
      </div>
    </div>
  </div>

  <!-- FAQ -->
  <div class="cd-faq">
    <div class="cd-wrap">
      <h2>Quick answers</h2>
      <details>
        <summary>Will the magnets hold a thick chignon?</summary>
        <p>Yes. Velvy "D" uses neodymium N52 magnets — the same grade used in industrial fasteners. It holds a thick, mid-length to long chignon without slipping, even on workouts or runs.</p>
      </details>
      <details>
        <summary>Is it safe near my phone, credit cards, or pacemaker?</summary>
        <p>The magnetic field is fully contained between the two plates when closed. It does not affect phones or contactless cards in normal use. If you have a pacemaker or implanted medical device, follow your physician's general guidance on magnetic accessories.</p>
      </details>
      <details>
        <summary>Does it leave a mark on my hair?</summary>
        <p>No. Unlike spring-loaded claws, there is no point pressure on the strand. The hold is distributed across the surface of the plate, so there's no visible kink when you take it out.</p>
      </details>
      <details>
        <summary>What's the return policy?</summary>
        <p>30 days, no questions asked. If the Velvy "D" isn't for you, send it back for a full refund.</p>
      </details>
      <details>
        <summary>Does this replace ALL my hair clips?</summary>
        <p>Honestly — most of them. We still wear small barrettes for half-up styles. But the giant claw clip you wear daily? Yes, this replaces that.</p>
      </details>

      <div style="text-align:center; margin-top:36px;">
        <a class="cd-btn" href="{{ product_url }}">Shop Velvy "D" — £11.99</a>
      </div>
    </div>
  </div>

</section>

