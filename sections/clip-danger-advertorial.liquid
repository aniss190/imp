<!-- STICKY MOBILE BAR -->
<div class="vd-sticky">
  <img src="{{ img_product }}" alt="Velvy D">
  <div class="info">
    <div class="name">Velvy "D" — flat magnetic</div>
    <div class="price">£11.99 <b>· Save 33%</b></div>
  </div>
  <a class="vd-btn alt" href="#vdShop">{{ cta_label }}</a>
</div>

<script>
(function(){
  var form    = document.getElementById('vdShopForm');
  if (!form) return;
  var swatches = form.querySelectorAll('.vd-shop-swatch');
  var thumbs   = form.querySelectorAll('.vd-shop-thumb');
  var main     = document.getElementById('vdShopMain');
  var colorEl  = document.getElementById('vdColorName');
  var cta      = document.getElementById('vdShopCta');
  var err      = document.getElementById('vdShopErr');
  var currentVariant = '57698262810959';

  swatches.forEach(function(b){
    b.addEventListener('click', function(){
      swatches.forEach(function(x){ x.classList.remove('active'); });
      b.classList.add('active');
      currentVariant = b.dataset.variant;
      colorEl.textContent = b.dataset.name;
    });
  });

  thumbs.forEach(function(t){
    t.addEventListener('click', function(){
      thumbs.forEach(function(x){ x.classList.remove('active'); });
      t.classList.add('active');
      main.src = t.dataset.src;
    });
  });

  form.addEventListener('submit', async function(e){
    e.preventDefault();
    err.style.display = 'none';
    cta.disabled = true;
    var origText = cta.textContent;
    cta.textContent = 'Adding...';
    try {
      var res = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ items: [{ id: parseInt(currentVariant, 10), quantity: 1 }] }),
      });
      if (!res.ok) throw new Error(await res.text());
      cta.textContent = 'Added ✓  Redirecting to checkout…';
      cta.setAttribute('data-state','added');
      if (typeof window.fbq === 'function') {
        try { window.fbq('track', 'AddToCart', { content_ids: [String(currentVariant)], value: 11.99, currency: 'GBP' }); } catch(e){}
      }
      setTimeout(function(){ window.location.href = '/checkout'; }, 700);
    } catch (ex) {
      console.error(ex);
      cta.textContent = origText;
      cta.disabled = false;
      err.style.display = 'block';
    }
  });
})();
</script>

