in-left: auto;\n  }\n\n  .klip-review__verified {\n    display: flex;\n    align-items: center;\n    gap: 4px;\n    font-size: 11.5px;\n    color: #00b67a;\n    font-weight: 400;\n  }\n\n  .klip-review__verified svg {\n    width: 12px;\n    height: 12px;\n    stroke: #00b67a;\n    fill: none;\n    stroke-width: 2.5;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n</style>\n\n<div class=\"klip-faq\">\n\n  <!-- Item 1 : All hair types -->\n  <div class=\"klip-faq__item\">\n    <button class=\"klip-faq__trigger\" aria-expanded=\"false\">\n      <div class=\"klip-faq__trigger-left\">\n        <div class=\"klip-faq__icon\">\n          <svg viewBox=\"0 0 24 24\"><path d=\"M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2\"></path><circle cx=\"9\" cy=\"7\" r=\"4\"></circle><path d=\"M23 21v-2a4 4 0 0 0-3-3.87\"></path><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"></path></svg>\n        </div>\n        <span class=\"klip-faq__title\">Does it work on all hair types?</span>\n      </div>\n      <div class=\"klip-faq__arrow\">\n        <svg viewBox=\"0 0 24 24\"><polyline points=\"6 9 12 15 18 9\"></polyline></svg>\n      </div>\n    </button>\n    <div class=\"klip-faq__body\">\n      <div class=\"klip-faq__body-inner\">\n        <div class=\"klip-faq__content\">\n          <p>Yes. VELVY™ is designed for all hair types, no exceptions. The key: simply adjust how much hair you take in the clip.</p>\n          <div class=\"klip-hair-grid\">\n            <div class=\"klip-hair-card\">\n              <div class=\"klip-hair-card__title\">Fine hair</div>\n              <div class=\"klip-hair-card__body\">You can take a more generous section — the magnet holds without crushing or pulling at the hair. No more readjusting every five minutes.</div>\n            </div>\n            <div class=\"klip-hair-card\">\n              <div class=\"klip-hair-card__title\">Thick hair</div>\n              <div class=\"klip-hair-card__body\">Take a smaller section to let the magnet close properly. The magnetic force adapts to your density and holds all day without effort.</div>\n            </div>\n            <div class=\"klip-hair-card\">\n              <div class=\"klip-hair-card__title\">Curly &amp; textured hair</div>\n              <div class=\"klip-hair-card__body\">No spring to snag or pull at your curls. The magnetic system holds without tugging, keeping your curls intact.</div>\n            </div>\n            <div class=\"klip-hair-card\">\n              <div class=\"klip-hair-card__title\">Straight hair</div>\n              <div class=\"klip-hair-card__body\">The magnet ensures a firm closure even on the slipperiest hair. It won't loosen, it won't fall out.</div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <!-- Item 2 : Specifications -->\n  <div class=\"klip-faq__item\">\n    <button class=\"klip-faq__trigger\" aria-expanded=\"false\">\n      <div class=\"klip-faq__trigger-left\">\n        <div class=\"klip-faq__icon\">\n          <svg viewBox=\"0 0 24 24\"><line x1=\"8\" y1=\"6\" x2=\"21\" y2=\"6\"></line><line x1=\"8\" y1=\"12\" x2=\"21\" y2=\"12\"></line><line x1=\"8\" y1=\"18\" x2=\"21\" y2=\"18\"></line><line x1=\"3\" y1=\"6\" x2=\"3.01\" y2=\"6\"></line><line x1=\"3\" y1=\"12\" x2=\"3.01\" y2=\"12\"></line><line x1=\"3\" y1=\"18\" x2=\"3.01\" y2=\"18\"></line></svg>\n        </div>\n        <span class=\"klip-faq__title\">Specifications</span>\n      </div>\n      <div class=\"klip-faq__arrow\">\n        <svg viewBox=\"0 0 24 24\"><polyline points=\"6 9 12 15 18 9\"></polyline></svg>\n      </div>\n    </button>\n    <div class=\"klip-faq__body\">\n      <div class=\"klip-faq__body-inner\">\n        <div class=\"klip-faq__content\">\n          <ul>\n            <li>Size: <strong>3 cm per part</strong> (2 pieces)</li>\n            <li>Closure: <strong>magnetic</strong></li>\n            <li>Design: <strong>ultra flat</strong></li>\n            <li>Compatible with: <strong>all hair types</strong></li>\n          </ul>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <!-- Item 3 : Shipping -->\n  <div class=\"klip-faq__item\">\n    <button class=\"klip-faq__trigger\" aria-expanded=\"false\">\n      <div class=\"klip-faq__trigger-left\">\n        <div class=\"klip-faq__icon\">\n          <svg viewBox=\"0 0 24 24\"><rect x=\"1\" y=\"3\" width=\"15\" height=\"13\" rx=\"1\"></rect><path d=\"M16 8h4l3 3v5h-7V8z\"></path><circle cx=\"5.5\" cy=\"18.5\" r=\"2.5\"></circle><circle cx=\"18.5\" cy=\"18.5\" r=\"2.5\"></circle></svg>\n        </div>\n        <span class=\"klip-faq__title\">Shipping & Delivery</span>\n      </div>\n      <div class=\"klip-faq__arrow\">\n        <svg viewBox=\"0 0 24 24\"><polyline points=\"6 9 12 15 18 9\"></polyline></svg>\n      </div>\n    </button>\n    <div class=\"klip-faq__body\">\n      <div class=\"klip-faq__body-inner\">\n        <div class=\"klip-faq__content\">\n          <p>Dispatched within <strong>48 hours</strong>. Once your order has shipped, estimated delivery times are:</p>\n          <div class=\"klip-delivery-grid\">\n            <div class=\"klip-delivery-row\"><span>🇬🇧 United Kingdom</span><span>7 – 14 days</span></div>\n            <div class=\"klip-delivery-row\"><span>🇮🇪 Ireland</span><span>7 – 14 days</span></div>\n            <div class=\"klip-delivery-row\"><span>🇫🇷 France</span><span>7 – 14 days</span></div>\n            <div class=\"klip-delivery-row\"><span>🇩🇪 Germany</span><span>7 – 14 days</span></div>\n            <div class=\"klip-delivery-row\"><span>🇺🇸 United States</span><span>7 – 14 days</span></div>\n            <div class=\"klip-delivery-row\"><span>🇦🇺 Australia</span><span>7 – 14 days</span></div>\n            <div class=\"klip-delivery-row\"><span>🇨🇦 Canada</span><span>7 – 14 days</span></div>\n            <div class=\"klip-delivery-row\"><span>🇳🇿 New Zealand</span><span>7 – 14 days</span></div>\n            <div class=\"klip-delivery-row\"><span>🌍 Rest of the world</span><span>7 – 20 days</span></div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <!-- Item 4 : What makes us different -->\n  <div class=\"klip-faq__item\">\n    <button class=\"klip-faq__trigger\" aria-expanded=\"false\">\n      <div class=\"klip-faq__trigger-left\">\n        <div class=\"klip-faq__icon\">\n          <svg viewBox=\"0 0 24 24\"><path d=\"M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z\"></path></svg>\n        </div>\n        <span class=\"klip-faq__title\">What makes us different</span>\n      </div>\n      <div class=\"klip-faq__arrow\">\n        <svg viewBox=\"0 0 24 24\"><polyline points=\"6 9 12 15 18 9\"></polyline></svg>\n      </div>\n    </button>\n    <div class=\"klip-faq__body\">\n      <div class=\"klip-faq__body-inner\">\n        <div class=\"klip-faq__content\">\n          <p>The hair clip hadn't changed in over <strong>125 years</strong>. VELVY™ reinvented everything. Its <strong>ultra-flat two-part magnetic design</strong> transforms the way you put your hair up: place, clip, done in two seconds.</p>\n          <p>Thanks to its completely flat shape, VELVY™ creates no bump at the back of your head — you can lean back, drive, work out or lie down without ever feeling it.</p>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <!-- Item 5 : Built to last -->\n  <div class=\"klip-faq__item\">\n    <button class=\"klip-faq__trigger\" aria-expanded=\"false\">\n      <div class=\"klip-faq__trigger-left\">\n        <div class=\"klip-faq__icon\">\n          <svg viewBox=\"0 0 24 24\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"></path></svg>\n        </div>\n        <span class=\"klip-faq__title\">Built to last</span>\n      </div>\n      <div class=\"klip-faq__arrow\">\n        <svg viewBox=\"0 0 24 24\"><polyline points=\"6 9 12 15 18 9\"></polyline></svg>\n      </div>\n    </button>\n    <div class=\"klip-faq__body\">\n      <div class=\"klip-faq__body-inner\">\n        <div class=\"klip-faq__content\">\n          <p>VELVY™ is designed to be <strong>the clip you never have to replace</strong>. With no fragile spring or plastic that cracks, its flat magnetic system handles repeated opening and closing, drops on the floor, and full days of wear.</p>\n          <p>The result: a virtually unbreakable clip that keeps its hold and its shape for a long, long time.</p>\n        </div>\n      </div>\n    </div>\n  </div>\n\n</div>\n\n<script>\n  document.querySelectorAll('.klip-faq__trigger').forEach(function(trigger) {\n    trigger.addEventListener('click', function() {\n      var item = this.closest('.klip-faq__item');\n      var isOpen = item.classList.contains('is-open');\n      document.querySelectorAll('.klip-faq__item').forEach(function(el) {\n        el.classList.remove('is-open');\n        el.querySelector('.klip-faq__trigger').setAttribute('aria-expanded', 'false');\n      });\n      if (!isOpen) {\n        item.classList.add('is-open');\n        trigger.setAttribute('aria-expanded', 'true');\n      }\n    });\n  });\n</script>"
