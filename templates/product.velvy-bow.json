      "settings": {
        "full_width": true,
        "remove_vertical_spacing": false,
        "remove_horizontal_spacing": false,
        "liquid": "<div class=\"velvy-reviews-section\">\n\n  <!-- Header -->\n  <div class=\"velvy-reviews-header\">\n    <div class=\"velvy-reviews-header-left\">\n      <div class=\"velvy-header-stars\">\n        <span class=\"velvy-sq-star\"></span>\n        <span class=\"velvy-sq-star\"></span>\n        <span class=\"velvy-sq-star\"></span>\n        <span class=\"velvy-sq-star\"></span>\n        <span class=\"velvy-sq-star velvy-sq-star--half\"></span>\n      </div>\n      <span class=\"velvy-reviews-count\">4 067+ Reviews</span>\n    </div>\n    <div class=\"velvy-reviews-header-right\">\n      <button class=\"velvy-btn-write\">Write a review</button>\n      <button class=\"velvy-btn-filter\">⚙</button>\n    </div>\n  </div>\n\n  <!-- Grid -->\n  <div class=\"velvy-reviews-grid\" id=\"velvyGrid\">\n\n    <!-- Review 1 -->\n    <div class=\"velvy-card\" data-index=\"1\">\n      <img src=\"https://cdn.shopify.com/s/files/1/1014/4959/7274/files/Capture_d_ecran_2026-04-01_a_10.24.27.png?v=1775031877\" alt=\"Customer review\" class=\"velvy-card-img\">\n      <div class=\"velvy-card-body\">\n        <div class=\"velvy-card-top\">\n          <span class=\"velvy-card-name\">Jessica Q.</span>\n          <span class=\"velvy-card-verified\">✔ Verified</span>\n        </div>\n        <div class=\"velvy-card-date\">13/04/2026</div>\n        <div class=\"velvy-card-stars\">\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n        </div>\n        <p class=\"velvy-card-text\">I wear it for every workout. An hour of cardio, abs, everything — it didn't move a single millimetre.</p>\n        <div class=\"velvy-card-product\">\n          <img src=\"https://cdn.shopify.com/s/files/1/1014/4959/7274/files/Capture_d_ecran_2026-04-01_a_10.24.27.png?v=1775031877\" class=\"velvy-card-thumb\">\n          <span>Velvy \"D\" – Magnetic Hair Clip</span>\n        </div>\n      </div>\n    </div>\n\n    <!-- Review 2 -->\n    <div class=\"velvy-card\" data-index=\"2\">\n      <img src=\"https://cdn.shopify.com/s/files/1/1014/4959/7274/files/Capture_d_ecran_2026-04-01_a_10.26.29.png?v=1775031996\" alt=\"Customer review\" class=\"velvy-card-img\">\n      <div class=\"velvy-card-body\">\n        <div class=\"velvy-card-top\">\n          <span class=\"velvy-card-name\">Maya I.</span>\n          <span class=\"velvy-card-verified\">✔ Verified</span>\n        </div>\n        <div class=\"velvy-card-date\">01/04/2026</div>\n        <div class=\"velvy-card-stars\">\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n        </div>\n        <p class=\"velvy-card-text\">With VELVY™, I can finally lean back without getting a headache. I keep it on all day without even thinking about it.</p>\n        <div class=\"velvy-card-product\">\n          <img src=\"https://cdn.shopify.com/s/files/1/1014/4959/7274/files/Capture_d_ecran_2026-04-01_a_10.26.29.png?v=1775031996\" class=\"velvy-card-thumb\">\n          <span>Velvy \"D\" – Magnetic Clip – Set of 2</span>\n        </div>\n      </div>\n    </div>\n\n    <!-- Review 3 -->\n    <div class=\"velvy-card\" data-index=\"3\">\n      <img src=\"https://cdn.shopify.com/s/files/1/1014/4959/7274/files/Capture_d_ecran_2026-04-01_a_10.32.36.png?v=1775032364\" alt=\"Customer review\" class=\"velvy-card-img\">\n      <div class=\"velvy-card-body\">\n        <div class=\"velvy-card-top\">\n          <span class=\"velvy-card-name\">Emily A.</span>\n          <span class=\"velvy-card-verified\">✔ Verified</span>\n        </div>\n        <div class=\"velvy-card-date\">08/01/2026</div>\n        <div class=\"velvy-card-stars\">\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n        </div>\n        <p class=\"velvy-card-text\">I have really thick hair and every clip I tried would slip out. This one stays put from morning to night without budging. Blown away.</p>\n        <div class=\"velvy-card-product\">\n          <img src=\"https://cdn.shopify.com/s/files/1/1014/4959/7274/files/Capture_d_ecran_2026-04-01_a_10.32.36.png?v=1775032364\" class=\"velvy-card-thumb\">\n          <span>Velvy \"D\" – Magnetic Hair Clip</span>\n        </div>\n      </div>\n    </div>\n\n    <!-- Review 4 -->\n    <div class=\"velvy-card\" data-index=\"4\">\n      <img src=\"https://cdn.shopify.com/s/files/1/1014/4959/7274/files/Capture_d_ecran_2026-04-01_a_10.23.01.png?v=1775031793\" alt=\"Customer review\" class=\"velvy-card-img\">\n      <div class=\"velvy-card-body\">\n        <div class=\"velvy-card-top\">\n          <span class=\"velvy-card-name\">Paula M.</span>\n          <span class=\"velvy-card-verified\">✔ Verified</span>\n        </div>\n        <div class=\"velvy-card-date\">24/02/2026</div>\n        <div class=\"velvy-card-stars\">\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n        </div>\n        <p class=\"velvy-card-text\">I just throw it in my bag like everything else and it doesn't break. No bent teeth, nothing.</p>\n        <div class=\"velvy-card-product\">\n          <img src=\"https://cdn.shopify.com/s/files/1/1014/4959/7274/files/Capture_d_ecran_2026-04-01_a_10.23.01.png?v=1775031793\" class=\"velvy-card-thumb\">\n          <span>Velvy \"D\" – Magnetic Clip – Set of 2</span>\n        </div>\n      </div>\n    </div>\n\n    <!-- Review 5 -->\n    <div class=\"velvy-card\" data-index=\"5\">\n      <img src=\"https://cdn.shopify.com/s/files/1/1014/4959/7274/files/Capture_d_ecran_2026-02-06_a_16.40.44.png?v=1770392453\" alt=\"Customer review\" class=\"velvy-card-img\">\n      <div class=\"velvy-card-body\">\n        <div class=\"velvy-card-top\">\n          <span class=\"velvy-card-name\">Sophie L.</span>\n          <span class=\"velvy-card-verified\">✔ Verified</span>\n        </div>\n        <div class=\"velvy-card-date\">15/03/2026</div>\n        <div class=\"velvy-card-stars\">\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n        </div>\n        <p class=\"velvy-card-text\">I didn't even realise my clip was giving me headaches. Since switching to Velvy, my evenings have been completely different.</p>\n        <div class=\"velvy-card-product\">\n          <img src=\"https://cdn.shopify.com/s/files/1/1014/4959/7274/files/Capture_d_ecran_2026-02-06_a_16.40.44.png?v=1770392453\" class=\"velvy-card-thumb\">\n          <span>Velvy \"D\" – Magnetic Hair Clip</span>\n        </div>\n      </div>\n    </div>\n\n    <!-- Review 6 -->\n    <div class=\"velvy-card velvy-card--hidden\" data-index=\"6\">\n      <img src=\"https://cdn.shopify.com/s/files/1/1014/4959/7274/files/Capture_d_ecran_2026-02-06_a_16.04.29.png?v=1770390282\" alt=\"Customer review\" class=\"velvy-card-img\">\n      <div class=\"velvy-card-body\">\n        <div class=\"velvy-card-top\">\n          <span class=\"velvy-card-name\">Charlotte R.</span>\n          <span class=\"velvy-card-verified\">✔ Verified</span>\n        </div>\n        <div class=\"velvy-card-date\">20/01/2026</div>\n        <div class=\"velvy-card-stars\">\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n        </div>\n        <p class=\"velvy-card-text\">My Velvy arrived on a Tuesday. By Wednesday I'd thrown out every other clip I owned. I only wish I'd found it sooner.</p>\n        <div class=\"velvy-card-product\">\n          <img src=\"https://cdn.shopify.com/s/files/1/1014/4959/7274/files/Capture_d_ecran_2026-02-06_a_16.04.29.png?v=1770390282\" class=\"velvy-card-thumb\">\n          <span>Velvy \"D\" – Magnetic Hair Clip</span>\n        </div>\n      </div>\n    </div>\n\n    <!-- Review 7 -->\n    <div class=\"velvy-card velvy-card--hidden\" data-index=\"7\">\n      <div class=\"velvy-card-body velvy-card-body--noimg\">\n        <div class=\"velvy-card-top\">\n          <span class=\"velvy-card-name\">Leah D.</span>\n          <span class=\"velvy-card-verified\">✔ Verified</span>\n        </div>\n        <div class=\"velvy-card-date\">10/02/2026</div>\n        <div class=\"velvy-card-stars\">\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n        </div>\n        <p class=\"velvy-card-text\">I don't even take it off at night — I literally forget it's there. First clip I've ever worn all day without any discomfort.</p>\n        <div class=\"velvy-card-product\">\n          <span>Velvy \"D\" – Magnetic Hair Clip</span>\n        </div>\n      </div>\n    </div>\n\n    <!-- Review 8 -->\n    <div class=\"velvy-card velvy-card--hidden\" data-index=\"8\">\n      <div class=\"velvy-card-body velvy-card-body--noimg\">\n        <div class=\"velvy-card-top\">\n          <span class=\"velvy-card-name\">Hannah T.</span>\n          <span class=\"velvy-card-verified\">✔ Verified</span>\n        </div>\n        <div class=\"velvy-card-date\">28/03/2026</div>\n        <div class=\"velvy-card-stars\">\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n        </div>\n        <p class=\"velvy-card-text\">In the car, at the gym, at the office — it doesn't move at all. It's the first clip where I genuinely forget I'm wearing anything in my hair.</p>\n        <div class=\"velvy-card-product\">\n          <span>Velvy \"D\" – Magnetic Hair Clip</span>\n        </div>\n      </div>\n    </div>\n\n    <!-- Review 9 -->\n    <div class=\"velvy-card velvy-card--hidden\" data-index=\"9\">\n      <div class=\"velvy-card-body velvy-card-body--noimg\">\n        <div class=\"velvy-card-top\">\n          <span class=\"velvy-card-name\">Isla B.</span>\n          <span class=\"velvy-card-verified\">✔ Verified</span>\n        </div>\n        <div class=\"velvy-card-date\">05/04/2026</div>\n        <div class=\"velvy-card-stars\">\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n        </div>\n        <p class=\"velvy-card-text\">Ever since I saw videos about the dangers of clips while driving, I couldn't wear one in the car. Velvy is the only one I actually feel safe wearing at the wheel.</p>\n        <div class=\"velvy-card-product\">\n          <span>Velvy \"D\" – Magnetic Hair Clip</span>\n        </div>\n      </div>\n    </div>\n\n    <!-- Review 10 -->\n    <div class=\"velvy-card velvy-card--hidden\" data-index=\"10\">\n      <div class=\"velvy-card-body velvy-card-body--noimg\">\n        <div class=\"velvy-card-top\">\n          <span class=\"velvy-card-name\">Chloe V.</span>\n          <span class=\"velvy-card-verified\">✔ Verified</span>\n        </div>\n        <div class=\"velvy-card-date\">18/04/2026</div>\n        <div class=\"velvy-card-stars\">\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n          <span class=\"velvy-sq-star velvy-sq-star--sm\"></span>\n        </div>\n        <p class=\"velvy-card-text\">I have very thick hair and every clip I tried would fall out. This one holds all day without moving an inch. Absolutely amazed.</p>\n        <div class=\"velvy-card-product\">\n          <span>Velvy \"D\" – Magnetic Clip – Set of 2</span>\n        </div>\n      </div>\n    </div>\n\n  </div>\n\n  <!-- Load more button -->\n  <div class=\"velvy-load-more-wrap\" id=\"velvyLoadMoreWrap\">\n    <button class=\"velvy-load-more\" id=\"velvyLoadMore\">Load more reviews</button>\n  </div>\n\n</div>\n\n<style>\n.velvy-reviews-section {\n  max-width: 1100px;\n  margin: 0 auto;\n  padding: 20px 16px;\n  font-family: inherit;\n}\n.velvy-reviews-header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  margin-bottom: 20px;\n  flex-wrap: wrap;\n  gap: 10px;\n}\n.velvy-reviews-header-left {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n}\n.velvy-header-stars { display: flex; gap: 2px; }\n.velvy-reviews-count { font-size: 15px; font-weight: 600; color: #222; }\n.velvy-reviews-header-right { display: flex; align-items: center; gap: 8px; }\n.velvy-btn-write {\n  border: 1.5px solid #ccc;\n  background: #fff;\n  border-radius: 6px;\n  padding: 7px 16px;\n  font-size: 13px;\n  font-weight: 500;\n  cursor: pointer;\n  color: #222;\n}\n.velvy-btn-filter {\n  border: 1.5px solid #ccc;\n  background: #fff;\n  border-radius: 6px;\n  padding: 7px 10px;\n  font-size: 14px;\n  cursor: pointer;\n}\n.velvy-sq-star {\n  display: inline-block;\n  width: 22px;\n  height: 22px;\n  background-color: #00b67a;\n  position: relative;\n  flex-shrink: 0;\n}\n.velvy-sq-star::after {\n  content: '';\n  position: absolute;\n  top: 50%; left: 50%;\n  transform: translate(-50%, -50%);\n  width: 15px; height: 15px;\n  background-color: #fff;\n  clip-path: polygon(50% 0%,61% 35%,98% 35%,68% 57%,79% 91%,50% 70%,21% 91%,32% 57%,2% 35%,39% 35%);\n}\n.velvy-sq-star--half { background: linear-gradient(to right, #00b67a 50%, #ddd 50%); }\n.velvy-sq-star--sm { width: 16px; height: 16px; }\n.velvy-sq-star--sm::after { width: 11px; height: 11px; }\n.velvy-reviews-grid { columns: 4; column-gap: 14px; }\n@media (max-width: 900px) { .velvy-reviews-grid { columns: 3; } }\n@media (max-width: 600px) { .velvy-reviews-grid { columns: 2; } }\n.velvy-card {\n  break-inside: avoid;\n  margin-bottom: 14px;\n  border: 1.5px solid #e8e8e8;\n  border-radius: 10px;\n  overflow: hidden;\n  background: #fff;\n}\n.velvy-card--hidden { display: none; }\n.velvy-card-img { width: 100%; display: block; object-fit: cover; max-height: 260px; }\n.velvy-card-body { padding: 12px; }\n.velvy-card-body--noimg { padding: 14px; }\n.velvy-card-top { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; margin-bottom: 2px; }\n.velvy-card-name { font-size: 13px; font-weight: 700; color: #111; }\n.velvy-card-verified { font-size: 11px; color: #00b67a; font-weight: 500; }\n.velvy-card-date { font-size: 11px; color: #888; margin-bottom: 6px; }\n.velvy-card-stars { display: flex; gap: 2px; margin-bottom: 8px; }\n.velvy-card-text { font-size: 12.5px; color: #333; line-height: 1.5; margin: 0 0 10px; }\n.velvy-card-product {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  border-top: 1px solid #f0f0f0;\n  padding-top: 8px;\n  font-size: 11px;\n  color: #555;\n}\n.velvy-card-thumb {\n  width: 36px; height: 36px;\n  object-fit: cover;\n  border-radius: 4px;\n  border: 1px solid #eee;\n  flex-shrink: 0;\n}\n.velvy-load-more-wrap { text-align: center; margin-top: 10px; }\n.velvy-load-more {\n  background: #fff;\n  border: 1.5px solid #222;\n  border-radius: 6px;\n  padding: 10px 28px;\n  font-size: 13px;\n  font-weight: 600;\n  cursor: pointer;\n  color: #222;\n  transition: background 0.2s, color 0.2s;\n}\n.velvy-load-more:hover { background: #222; color: #fff; }\n</style>\n\n<script>\ndocument.getElementById('velvyLoadMore').addEventListener('click', function() {\n  var hidden = document.querySelectorAll('.velvy-card--hidden');\n  var count = 0;\n  hidden.forEach(function(card) {\n    if (count < 5) {\n      card.classList.remove('velvy-card--hidden');\n      count++;\n    }\n  });\n  if (document.querySelectorAll('.velvy-card--hidden').length === 0) {\n    document.getElementById('velvyLoadMoreWrap').style.display = 'none';\n  }\n});\n</script>",
