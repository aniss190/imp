        "liquid_zbGibW": {
          "type": "liquid",
          "settings": {
            "liquid": "<style>\n  .klip-reassurance {\n    width: 100%;\n    background: transparent;\n    border: none;\n    padding: 30px 0;\n    display: flex;\n    justify-content: stretch;\n    align-items: flex-start;\n  }\n  .klip-reassurance__item:nth-child(1) { animation-delay: 0.05s; }\n  .klip-reassurance__item:nth-child(3) { animation-delay: 0.15s; }\n  .klip-reassurance__item:nth-child(5) { animation-delay: 0.25s; }\n  @keyframes klipFadeUp {\n    to { opacity: 1; transform: translateY(0); }\n  }\n  .klip-reassurance__icon {\n    width: 48px;\n    height: 48px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    background: rgba(245, 201, 188, 0.3);\n    border-radius: 50%;\n    box-shadow: 0 2px 12px rgba(180,100,80,0.08);\n    transition: background 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;\n  }\n  .klip-reassurance__item:hover .klip-reassurance__icon {\n    background: rgba(245, 201, 188, 0.55);\n    transform: translateY(-2px);\n    box-shadow: 0 6px 18px rgba(180,100,80,0.15);\n  }\n  .klip-reassurance__icon svg {\n    width: 22px;\n    height: 22px;\n    stroke: #b05a45;\n    fill: none;\n    stroke-width: 1.6;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n    transition: stroke 0.3s ease;\n  }\n  .klip-reassurance__item:hover .klip-reassurance__icon svg {\n    stroke: #8c3d2a;\n  }\n  .klip-reassurance__item {\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: flex-start;\n    gap: 0;\n    text-align: center;\n    opacity: 0;\n    transform: translateY(10px);\n    animation: klipFadeUp 0.55s cubic-bezier(0.22, 1, 0.36, 1) forwards;\n  }\n  .klip-reassurance__icon-wrap {\n    height: 48px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n  .klip-reassurance__text {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 3px;\n    margin-top: 12px;\n  }\n  .klip-reassurance__label {\n    font-family: 'DM Sans', sans-serif;\n    font-weight: 400;\n    font-size: 17px;\n    color: #2c1a15;\n    line-height: 1.35;\n  }\n  .klip-reassurance__sublabel {\n    font-family: 'DM Sans', sans-serif;\n    font-weight: 400;\n    font-size: 12px;\n    color: #8a6e66;\n    line-height: 1.3;\n  }\n  .klip-reassurance__divider {\n    width: 1px;\n    height: 48px;\n    background: linear-gradient(to bottom, transparent, rgba(180,100,80,0.2), transparent);\n  }\n  @media (max-width: 768px) {\n    .klip-reassurance { padding: 20px 0; gap: 0; }\n    .klip-reassurance__item { flex: 1; padding: 0 4px; }\n    .klip-reassurance__icon { width: 38px; height: 38px; }\n    .klip-reassurance__icon svg { width: 18px; height: 18px; }\n    .klip-reassurance__label { font-size: 13px; }\n    .klip-reassurance__sublabel { font-size: 11px; }\n    .klip-reassurance__divider { width: 1px; height: 40px; flex-shrink: 0; }\n  }\n</style>\n\n<div class=\"klip-reassurance\">\n\n  <div class=\"klip-reassurance__item\">\n    <div class=\"klip-reassurance__icon-wrap\">\n      <div class=\"klip-reassurance__icon\">\n        <svg viewBox=\"0 0 24 24\"><rect x=\"1\" y=\"3\" width=\"15\" height=\"13\" rx=\"1\"></rect><path d=\"M16 8h4l3 3v5h-7V8z\"></path><circle cx=\"5.5\" cy=\"18.5\" r=\"2.5\"></circle><circle cx=\"18.5\" cy=\"18.5\" r=\"2.5\"></circle></svg>\n      </div>\n    </div>\n    <div class=\"klip-reassurance__text\">\n      <span class=\"klip-reassurance__label\">Fast shipping</span>\n    </div>\n  </div>\n\n  <div class=\"klip-reassurance__divider\"></div>\n\n  <div class=\"klip-reassurance__item\">\n    <div class=\"klip-reassurance__icon-wrap\">\n      <div class=\"klip-reassurance__icon\">\n        <svg viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"9\"></circle><polyline points=\"12 7 12 12 15 15\"></polyline></svg>\n      </div>\n    </div>\n    <div class=\"klip-reassurance__text\">\n      <span class=\"klip-reassurance__label\">Shipped within 48h</span>\n    