            "liquid": "<style>\n  .klip-faq {\n    width: 100%;\n    max-width: 720px;\n    margin: 0 auto;\n    padding: 8px 0;\n    font-family: 'DM Sans', sans-serif;\n  }\n\n  .klip-faq__item {\n    border-bottom: 1px solid #edddd7;\n    overflow: hidden;\n  }\n\n  .klip-faq__item:first-child {\n    border-top: 1px solid #edddd7;\n  }\n\n  .klip-faq__trigger {\n    width: 100%;\n    background: none;\n    border: none;\n    cursor: pointer;\n    padding: 22px 0;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 16px;\n    text-align: left;\n  }\n\n  .klip-faq__trigger-left {\n    display: flex;\n    align-items: center;\n    gap: 16px;\n  }\n\n  .klip-faq__icon {\n    width: 36px;\n    height: 36px;\n    flex-shrink: 0;\n    background: rgba(245, 201, 188, 0.3);\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: background 0.3s ease;\n  }\n\n  .klip-faq__item.is-open .klip-faq__icon,\n  .klip-faq__trigger:hover .klip-faq__icon {\n    background: rgba(245, 201, 188, 0.65);\n  }\n\n  .klip-faq__icon svg {\n    width: 16px;\n    height: 16px;\n    stroke: #b05a45;\n    fill: none;\n    stroke-width: 1.6;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  .klip-faq__title {\n    font-family: 'Cormorant Garamond', serif;\n    font-weight: 500;\n    font-size: 20px;\n    color: #2c1a15;\n    letter-spacing: 0.01em;\n    line-height: 1.2;\n  }\n\n  .klip-faq__arrow {\n    flex-shrink: 0;\n    width: 20px;\n    height: 20px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);\n  }\n\n  .klip-faq__arrow svg {\n    width: 14px;\n    height: 14px;\n    stroke: #b05a45;\n    fill: none;\n    stroke-width: 1.8;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  .klip-faq__item.is-open .klip-faq__arrow {\n    transform: rotate(180deg);\n  }\n\n  .klip-faq__body {\n    display: grid;\n    grid-template-rows: 0fr;\n    transition: grid-template-rows 0.4s cubic-bezier(0.22, 1, 0.36, 1);\n  }\n\n  .klip-faq__item.is-open .klip-faq__body {\n    grid-template-rows: 1fr;\n  }\n\n  .klip-faq__body-inner {\n    overflow: hidden;\n  }\n\n  .klip-faq__content {\n    padding: 0 0 24px 52px;\n    font-family: 'DM Sans', sans-serif;\n    font-weight: 300;\n    font-size: 14.5px;\n    color: #6b4c43;\n    line-height: 1.75;\n  }\n\n  .klip-faq__content p { margin-bottom: 10px; }\n  .klip-faq__content p:last-child { margin-bottom: 0; }\n\n  .klip-faq__content ul {\n    list-style: none;\n    padding: 0;\n    margin: 10px 0 0;\n    display: flex;\n    flex-direction: column;\n    gap: 4px;\n  }\n\n  .klip-faq__content ul li {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n  }\n\n  .klip-faq__content ul li::before {\n    content: '';\n    width: 4px;\n    height: 4px;\n    border-radius: 50%;\n    background: #e8a090;\n    flex-shrink: 0;\n  }\n\n  .klip-faq__badge {\n    display: inline-block;\n    font-family: 'DM Sans', sans-serif;\n    font-size: 10px;\n    font-weight: 400;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n    color: #b05a45;\n    background: rgba(245, 201, 188, 0.35);\n    border-radius: 20px;\n    padding: 3px 10px;\n    margin-left: 10px;\n    vertical-align: middle;\n  }\n\n  /* Hair type cards */\n  .klip-hair-grid {\n    display: flex;\n    flex-direction: column;\n    gap: 8px;\n    margin-top: 12px;\n  }\n\n  .klip-hair-card {\n    background: #fdf8f6;\n    border: 1px solid #edddd7;\n    border-radius: 10px;\n    padding: 12px 14px;\n  }\n\n  .klip-hair-card__title {\n    font-family: 'DM Sans', sans-serif;\n    font-weight: 400;\n    font-size: 13px;\n    color: #b05a45;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n    margin-bottom: 5px;\n  }\n\n  .klip-hair-card__body {\n    font-family: 'DM Sans', sans-serif;\n    font-weight: 300;\n    font-size: 13.5px;\n    color: #6b4c43;\n    line-height: 1.65;\n  }\n\n  /* Grille livraison */\n  .klip-delivery-grid {\n    display: flex;\n    flex-direction: column;\n    gap: 0;\n    border: 1px solid #edddd7;\n    border-radius: 10px;\n    overflow: hidden;\n    margin-top: 12px;\n  }\n\n  .klip-delivery-row {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 9px 13px;\n    font-size: 13px;\n    color: #6b4c43;\n    border-bottom: 1px solid #edddd7;\n  }\n\n  .klip-delivery-row:last-child { border-bottom: none; }\n  .klip-delivery-row:nth-child(odd) { background: #fff; }\n  .klip-delivery-row:nth-child(even) { background: #fdf8f6; }\n\n  .klip-delivery-row span:last-child {\n    font-weight: 600;\n    color: #b05a45;\n  }\n\n  @media (max-width: 600px) {\n    .klip-faq__title { font-size: 17px; }\n    .klip-faq__content { padding-left: 0; font-size: 13.5px; }\n    .klip-faq__trigger { padding: 18px 0; }\n  }\n</style>\n\n<div class=\"klip-review\">\n  <div class=\"klip-review__header\">\n    <div class=\"klip-review__stars\">\n      <svg viewBox=\"0 0 22 22\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <rect width=\"22\" height=\"22\" rx=\"2\" fill=\"#00b67a\"></rect>\n        <path d=\"M11 4l1.854 5.705H18.5l-4.927 3.58 1.854 5.705L11 15.41l-4.427 3.58 1.854-5.705L3.5 9.705H9.146L11 4z\" fill=\"white\"></path>\n      </svg>\n      <svg viewBox=\"0 0 22 22\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <rect width=\"22\" height=\"22\" rx=\"2\" fill=\"#00b67a\"></rect>\n        <path d=\"M11 4l1.854 5.705H18.5l-4.927 3.58 1.854 5.705L11 15.41l-4.427 3.58 1.854-5.705L3.5 9.705H9.146L11 4z\" fill=\"white\"></path>\n      </svg>\n      <svg viewBox=\"0 0 22 22\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <rect width=\"22\" height=\"22\" rx=\"2\" fill=\"#00b67a\"></rect>\n        <path d=\"M11 4l1.854 5.705H18.5l-4.927 3.58 1.854 5.705L11 15.41l-4.427 3.58 1.854-5.705L3.5 9.705H9.146L11 4z\" fill=\"white\"></path>\n      </svg>\n      <svg viewBox=\"0 0 22 22\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <rect width=\"22\" height=\"22\" rx=\"2\" fill=\"#00b67a\"></rect>\n        <path d=\"M11 4l1.854 5.705H18.5l-4.927 3.58 1.854 5.705L11 15.41l-4.427 3.58 1.854-5.705L3.5 9.705H9.146L11 4z\" fill=\"white\"></path>\n      </svg>\n      <svg viewBox=\"0 0 22 22\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <rect width=\"22\" height=\"22\" rx=\"2\" fill=\"#00b67a\"></rect>\n        <path d=\"M11 4l1.854 5.705H18.5l-4.927 3.58 1.854 5.705L11 15.41l-4.427 3.58 1.854-5.705L3.5 9.705H9.146L11 4z\" fill=\"white\"></path>\n      </svg>\n    </div>\n    <div class=\"klip-review__trustpilot\">\n      <div class=\"klip-review__trustpilot-logo\">\n        <div class=\"tp-star\">\n          <svg viewBox=\"0 0 22 22\"><path d=\"M11 4l1.854 5.705H18.5l-4.927 3.58 1.854 5.705L11 15.41l-4.427 3.58 1.854-5.705L3.5 9.705H9.146L11 4z\"></path></svg>\n        </div>\n        <span class=\"klip-review__trustpilot-text\"><span>Verified Review</span></span>\n      </div>\n    </div>\n  </div>\n  <p class=\"klip-review__body\">\n    In the car, on a plane, on the sofa… I always used to end up taking my hair down. The flat clip is a total game changer — I can barely feel it, even leaning against a seat. I keep my hair up without even thinking about it.\n  </p>\n  <div class=\"klip-review__footer\">\n    <div class=\"klip-review__avatar\">LM</div>\n    <div>\n      <div class=\"klip-review__author\">Lucy M.</div>\n      <div class=\"klip-review__verified\">\n        <svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n        Verified purchase\n      </div>\n    </div>\n    <span class=\"klip-review__date\">3 days ago</span>\n  </div>\n</div>"
          }
